#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd)"

cd "$REPO_ROOT"

print_usage() {
  cat <<'USAGE'
Usage:
  bash scripts/dev/erp-agent-task-start

Purpose:
  Run the standard integrated task-start baseline for executable agent tasks.

Behavior:
  - never reads, sources, copies, displays, or creates .env
  - never touches secrets
  - runs from the repository root
  - prints branch, commits, status, open PRs, recent main CI, worktrees
  - runs orchestrator and task queue validation
  - reports untracked files separately
  - explicitly flags the local F140D audit report if present

Notes:
  This helper is intended to be invoked from scripts/dev/erp-logged-run.
  Plan-only agents should propose this command to the human supervisor instead of running it.
USAGE
}

case "${1:-}" in
  help|--help|-h)
    print_usage
    exit 0
    ;;
  "")
    ;;
  *)
    echo "ERROR: unexpected argument '$1'"
    print_usage
    exit 2
    ;;
esac

current_branch="$(git branch --show-current 2>/dev/null || true)"

echo "============================================================"
echo "ERP AGENT TASK START"
echo "============================================================"
echo "REPO_ROOT: $REPO_ROOT"
echo "BRANCH: ${current_branch:-DETACHED}"

git fetch origin --prune

if [ "${current_branch:-}" = "main" ]; then
  git pull --ff-only origin main || echo "WARN: unable to fast-forward local main."
else
  echo "INFO: not on main; skip local main pull."
fi

echo
echo "==== RECENT COMMITS ===="
git log --oneline --decorate -8

echo
echo "==== GIT STATUS ===="
git status --short

echo
echo "==== OPEN PRS ===="
gh pr list --state open --limit 20

echo
echo "==== RECENT MAIN CI RUNS ===="
gh run list --branch main --limit 10

echo
echo "==== WORKTREES ===="
bash "$SCRIPT_DIR/erp-worktree-list-validated"

echo
echo "==== ORCHESTRATOR CHECK ===="
bash "$SCRIPT_DIR/erp-orchestrator-state-check"

echo
echo "==== TASK QUEUE VALIDATION ===="
bash "$SCRIPT_DIR/erp-task-queue-validate"

echo
echo "==== UNTRACKED FILES ===="
git ls-files --others --exclude-standard || true

if [ -e "$REPO_ROOT/docs/audits/F140D_OPENCODE_WSL_NATIVE_EVALUATION.md" ]; then
  echo "F140D_LOCAL_UNTRACKED: docs/audits/F140D_OPENCODE_WSL_NATIVE_EVALUATION.md"
fi
