#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCANNER="$SCRIPT_DIR/erp-secret-scan-local"
TMP_ROOT="$(mktemp -d)"

cleanup() {
  rm -rf -- "$TMP_ROOT"
}
trap cleanup EXIT

REPO="$TMP_ROOT/repo"
mkdir -p "$REPO/scripts/dev" "$REPO/backend"
cp "$SCANNER" "$REPO/scripts/dev/erp-secret-scan-local"
chmod +x "$REPO/scripts/dev/erp-secret-scan-local"

git -C "$REPO" init -q -b main
git -C "$REPO" config user.name "ERP Scanner Test"
git -C "$REPO" config user.email "scanner-test@example.invalid"
printf '%s\n' 'baseline' > "$REPO/README.md"
git -C "$REPO" add README.md scripts/dev/erp-secret-scan-local
git -C "$REPO" commit -qm "test baseline"

{
  printf '%s%s\n' 'password ' '= serializers.CharField(write_only=True)'
  printf '%s%s\n' 'password' '=serializer.validated_data["password"]'
  printf '%s%s\n' 'token ' '= _csrf_token(request)'
  printf '%s%s\n' 'token ' '= generated_token'
} > "$REPO/backend/non_secret_expressions.py"

"$REPO/scripts/dev/erp-secret-scan-local" >/dev/null
"$REPO/scripts/dev/erp-secret-scan-local" --all >/dev/null

assert_detected() {
  local output
  if output=$("$REPO/scripts/dev/erp-secret-scan-local" 2>&1); then
    echo "ERROR: expected a generic secret assignment finding" >&2
    exit 1
  fi
  if ! printf '%s\n' "$output" | grep -q 'generic_secret_assignment'; then
    echo "ERROR: expected generic_secret_assignment label" >&2
    exit 1
  fi
}

printf '%s%s%s\n' 'password ' '= "' 'literal-password-value"' \
  > "$REPO/backend/quoted_literal.py"
assert_detected

rm -f "$REPO/backend/quoted_literal.py"
high_entropy_value='Abcd1234Efgh5678_token'
printf '%s%s\n' 'token = ' "$high_entropy_value" \
  > "$REPO/backend/high_entropy_literal.py"
assert_detected

rm -f "$REPO/backend/high_entropy_literal.py"
printf '%s%s\n' 'password' ': plain-text-value' > "$REPO/config.yaml"
assert_detected

echo "erp-secret-scan-local regression tests passed."
