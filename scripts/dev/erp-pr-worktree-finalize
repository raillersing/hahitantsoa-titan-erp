#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd)"

cd "$REPO_ROOT"

PR_NUMBER=""
WORKTREE_PATH=""
BRANCH=""

gh_retry() {
  local attempt=1
  local max_attempts="${GH_RETRY_ATTEMPTS:-4}"
  local delay_seconds="${GH_RETRY_DELAY_SECONDS:-5}"

  while true; do
    if "$@"; then
      return 0
    fi

    if [ "$attempt" -ge "$max_attempts" ]; then
      echo "ERROR: command failed after $attempt attempt(s): $*" >&2
      return 1
    fi

    echo "WARN: transient GitHub command failure (attempt $attempt/$max_attempts): $*" >&2
    sleep "$delay_seconds"
    attempt=$((attempt + 1))
  done
}

print_usage() {
  cat <<'USAGE'
Usage:
  scripts/dev/erp-pr-worktree-finalize <pr-number> [options]

Options:
  --worktree <path>     Path to the worktree to remove after merge (default: current worktree path).
  --branch <branch>     Branch to delete after merge (default: current branch).
  --help                Show this help.

Purpose:
  Safely finalize a PR from its own dedicated task worktree by:
  - requiring execution from the task worktree (not root/main)
  - requiring a clean worktree and valid PR argument
  - allowing PR state OPEN for merge or MERGED for post-merge recovery
  - requiring mergeable MERGEABLE only when the PR still needs merging
  - requiring all CI checks completed with success before merge
  - merging with gh pr merge --squash --match-head-commit and without --delete-branch
  - confirming PR state becomes MERGED and main CI is green
  - switching to the main repository root (MAIN_PATH from git worktree list) to
    sync main, because the task worktree is still on the feature branch
  - cleaning the task worktree Docker Compose project by explicit project name
  - removing the clean worktree with git worktree remove
  - deleting the local branch with git branch -D after MERGED confirmation
  - deleting the remote branch with git push origin --delete --prune
  - pruning stale worktree metadata

Hard stops:
  - Worktree is dirty
  - PR is neither OPEN nor MERGED
  - PR is OPEN but not MERGEABLE
  - Any CI check is still pending or has failed
  - PR does not become MERGED after merge attempt
  - Main CI is not green
  - Worktree removal fails
  - Branch is checked out in another worktree
  - Branch or PR arguments are missing

Notes:
  This helper never reads, sources, prints, copies, or creates .env.
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --worktree)
      shift
      WORKTREE_PATH="${1:-}"
      ;;
    --branch)
      shift
      BRANCH="${1:-}"
      ;;
    --help|-h|help)
      print_usage
      exit 0
      ;;
    -*)
      echo "ERROR: unknown option: $1"
      print_usage
      exit 2
      ;;
    *)
      if [ -n "$PR_NUMBER" ]; then
        echo "ERROR: only one PR number may be provided"
        print_usage
        exit 2
      fi
      PR_NUMBER="$1"
      ;;
  esac
  shift
done

if [ -z "$PR_NUMBER" ]; then
  print_usage
  exit 2
fi

require_option_value() {
  local name="$1"
  local value="$2"
  if [ -z "$value" ] || [[ "$value" == --* ]]; then
    echo "ERROR: missing value for $name"
    exit 2
  fi
}

if [ -n "$WORKTREE_PATH" ]; then
  require_option_value "--worktree" "$WORKTREE_PATH"
fi
if [ -n "$BRANCH" ]; then
  require_option_value "--branch" "$BRANCH"
fi

# ----- Hard stop: must not be the main-root worktree -----
CURRENT_PATH="$(cd "$REPO_ROOT" && pwd -P)"
MAIN_PATH=""
while IFS= read -r line; do
  case "$line" in
    worktree\ *)
      path="${line#worktree }"
      if [ -z "$MAIN_PATH" ]; then
        MAIN_PATH="$path"
      fi
      ;;
  esac
done < <(git worktree list --porcelain)

if [ "$CURRENT_PATH" = "$MAIN_PATH" ]; then
  echo "ERROR: this script must run from the task worktree, not from root/main."
  echo "Use scripts/dev/erp-pr-finalize-from-root for root-based finalization."
  exit 1
fi

# ----- Hard stop: worktree must be clean -----
STATUS_OUTPUT="$(git status --short)"
if [ -n "$STATUS_OUTPUT" ]; then
  echo "ERROR: worktree is dirty. Commit or stash changes before finalizing."
  printf '%s\n' "$STATUS_OUTPUT"
  exit 1
fi
echo "OK: worktree is clean."

# ----- Determine worktree and branch (default to current) -----
if [ -z "$WORKTREE_PATH" ]; then
  WORKTREE_PATH="$CURRENT_PATH"
fi
if [ -z "$BRANCH" ]; then
  BRANCH="$(git branch --show-current 2>/dev/null || true)"
  if [ -z "$BRANCH" ]; then
    echo "ERROR: cannot determine current branch. Provide --branch."
    exit 1
  fi
fi

# ----- Hard stop: branch must not be main/master -----
case "$BRANCH" in
  main|master)
    echo "ERROR: refusing to finalize protected branch: $BRANCH"
    exit 1
    ;;
esac

# ----- Hard stop: worktree path must not be the main repo -----
if [ "$WORKTREE_PATH" = "$MAIN_PATH" ]; then
  echo "ERROR: refusing to remove the main repository worktree"
  exit 1
fi

# ----- Hard stop: worktree must exist -----
if [ ! -d "$WORKTREE_PATH" ]; then
  echo "ERROR: worktree path not found: $WORKTREE_PATH"
  exit 1
fi

echo "PR: #$PR_NUMBER"
echo "WORKTREE: $WORKTREE_PATH"
echo "BRANCH: $BRANCH"

# ----- Fetch PR metadata -----
PR_HEAD_SHA="$(gh_retry gh pr view "$PR_NUMBER" --json headRefOid --jq '.headRefOid')"
PR_STATE="$(gh_retry gh pr view "$PR_NUMBER" --json state --jq '.state')"
PR_MERGEABLE="$(gh_retry gh pr view "$PR_NUMBER" --json mergeable --jq '.mergeable')"
PR_TITLE="$(gh_retry gh pr view "$PR_NUMBER" --json title --jq '.title')"
PR_BASE_BRANCH="$(gh_retry gh pr view "$PR_NUMBER" --json baseRefName --jq '.baseRefName')"
PR_HEAD_BRANCH="$(gh_retry gh pr view "$PR_NUMBER" --json headRefName --jq '.headRefName')"

if [ "$PR_BASE_BRANCH" != "main" ]; then
  echo "ERROR: PR #$PR_NUMBER does not target main (targets: $PR_BASE_BRANCH)"
  exit 1
fi

if [ "$PR_HEAD_BRANCH" != "$BRANCH" ]; then
  echo "ERROR: PR head branch '$PR_HEAD_BRANCH' differs from task branch '$BRANCH'"
  exit 1
fi

# ----- Hard stop: branch must not be checked out in another worktree -----
BRANCH_WORKTREE_COUNT="$(git worktree list --porcelain | grep -c "refs/heads/$BRANCH" 2>/dev/null || true)"
if [ "$BRANCH_WORKTREE_COUNT" -gt 1 ]; then
  echo "ERROR: branch '$BRANCH' is checked out in $BRANCH_WORKTREE_COUNT worktrees."
  echo "Each task must use one dedicated branch in one dedicated worktree."
  git worktree list | grep "refs/heads/$BRANCH" || true
  exit 1
fi

# ----- Hard stop: PR must be OPEN or MERGED -----
if [ "$PR_STATE" != "OPEN" ] && [ "$PR_STATE" != "MERGED" ]; then
  echo "ERROR: PR #$PR_NUMBER must be OPEN or MERGED; got $PR_STATE"
  exit 1
fi

# ----- Hard stop: OPEN PR must be mergeable -----
if [ "$PR_STATE" = "OPEN" ] && [ "$PR_MERGEABLE" != "MERGEABLE" ]; then
  echo "ERROR: PR #$PR_NUMBER is not mergeable: $PR_MERGEABLE"
  exit 1
fi

if [ "$PR_STATE" = "OPEN" ]; then
  # ----- Hard stop: all CI checks must be completed with success -----
  echo "INFO: Validating CI checks for PR #$PR_NUMBER..."
  # First check: gh pr checks --required (preferred when configured)
  required_ok=0
  if gh_retry gh pr checks "$PR_NUMBER" --required >/dev/null 2>&1; then
    required_ok=1
  fi

  if [ "$required_ok" -eq 1 ]; then
    echo "OK: Required checks verified via gh pr checks --required."
  else
    echo "INFO: gh pr checks --required did not report success. Validating statusCheckRollup..."
  fi

  # Always validate full statusCheckRollup for pending checks
  PENDING_COUNT="$(gh_retry gh pr view "$PR_NUMBER" --json statusCheckRollup --jq '[.statusCheckRollup[] | select(.status != "COMPLETED")] | length' 2>/dev/null || echo "0")"
  if [ "${PENDING_COUNT:-0}" -gt 0 ]; then
    echo "ERROR: One or more CI checks are still pending. Wait for completion before finalizing."
    gh_retry gh pr view "$PR_NUMBER" --json statusCheckRollup --jq '.statusCheckRollup[] | select(.status != "COMPLETED") | "Check run \(.name) is \(.status)"'
    exit 1
  fi

  FAILED_COUNT="$(gh_retry gh pr view "$PR_NUMBER" --json statusCheckRollup --jq '[.statusCheckRollup[] | select(.conclusion != "SUCCESS" and .conclusion != "NEUTRAL" and .conclusion != "SKIPPED" and .conclusion != null)] | length' 2>/dev/null || echo "0")"
  if [ "${FAILED_COUNT:-0}" -gt 0 ]; then
    echo "ERROR: One or more CI checks have failed."
    gh_retry gh pr view "$PR_NUMBER" --json statusCheckRollup --jq '.statusCheckRollup[] | select(.conclusion != "SUCCESS" and .conclusion != "NEUTRAL" and .conclusion != "SKIPPED" and .conclusion != null) | "Check run \(.name) is \(.conclusion)"'
    exit 1
  fi

  echo "OK: All CI checks completed with success."
else
  echo "INFO: PR #$PR_NUMBER is already MERGED. Skipping mergeability and PR-CI merge gating, and continuing with main CI verification plus cleanup."
fi

if [ "$PR_STATE" = "OPEN" ]; then
  # ----- Merge PR without --delete-branch -----
  echo "INFO: Merging PR #$PR_NUMBER..."
  gh_retry gh pr merge "$PR_NUMBER" --squash --match-head-commit "$PR_HEAD_SHA"

  echo "INFO: Waiting for PR state to become MERGED..."
  for attempt in $(seq 1 30); do
    PR_STATE="$(gh_retry gh pr view "$PR_NUMBER" --json state --jq '.state')"
    if [ "$PR_STATE" = "MERGED" ]; then
      echo "OK: PR #$PR_NUMBER is MERGED."
      break
    fi
    if [ "$attempt" -eq 30 ]; then
      echo "ERROR: PR #$PR_NUMBER did not become MERGED within timeout (state: $PR_STATE)"
      exit 1
    fi
    sleep 5
  done
else
  echo "OK: PR #$PR_NUMBER is already MERGED."
fi

# ----- Sync main from the root worktree -----
# After a squash merge the task branch is no longer an ancestor of origin/main, so
# pulling origin/main into the task branch would fail. Switch to the root worktree
# (which must remain on main) and fast-forward main from there.
# MAIN_PATH was derived from git worktree list --porcelain (first entry is the main repo).
echo "INFO: Returning to root worktree to sync main..."
if [ -z "$MAIN_PATH" ]; then
  echo "ERROR: MAIN_PATH is empty; cannot determine main repository path"
  exit 1
fi
if [ ! -d "$MAIN_PATH" ]; then
  echo "ERROR: main repository path missing: $MAIN_PATH"
  exit 1
fi
cd "$MAIN_PATH"

if [ "$(git branch --show-current)" != "main" ]; then
  echo "ERROR: MAIN_PATH is not on main; cannot sync main safely"
  exit 1
fi

git fetch origin --prune
git pull --ff-only origin main

# ----- Hard stop: wait for main CI green -----
CURRENT_MAIN_SHA="$(git rev-parse HEAD)"
echo "INFO: Waiting for main CI run for SHA $CURRENT_MAIN_SHA..."

MAIN_CI_RUN_ID=""
for attempt in $(seq 1 45); do
  MAIN_CI_RUN_ID="$(gh_retry gh run list --branch main --event push --limit 20 --json databaseId,headSha --jq ".[] | select(.headSha == \"$CURRENT_MAIN_SHA\") | .databaseId" 2>/dev/null | head -n 1 || true)"
  if [ -n "$MAIN_CI_RUN_ID" ]; then
    echo "OK: Found main CI run: $MAIN_CI_RUN_ID"
    break
  fi
  echo "INFO: Awaiting CI trigger... (attempt $attempt/45)"
  sleep 10
done

if [ -z "$MAIN_CI_RUN_ID" ]; then
  echo "ERROR: No main CI run found for SHA $CURRENT_MAIN_SHA"
  exit 1
fi

STATUS="$(gh_retry gh run view "$MAIN_CI_RUN_ID" --json status --jq '.status')"
if [ "$STATUS" != "completed" ]; then
  echo "INFO: Main CI run is $STATUS. Watching run $MAIN_CI_RUN_ID..."
  gh_retry gh run watch "$MAIN_CI_RUN_ID" --interval 30 --exit-status || true
fi

CONCLUSION="$(gh_retry gh run view "$MAIN_CI_RUN_ID" --json conclusion --jq '.conclusion')"
if [ "$CONCLUSION" != "success" ]; then
  echo "ERROR: Main CI run conclusion is: $CONCLUSION (expected success)"
  exit 1
fi

echo "OK: Main CI is green."

# ----- Docker cleanup before worktree removal -----
echo "INFO: Cleaning up Docker Compose project for worktree..."
WORKTREE_COMPOSE_PROJECT="$(basename "$WORKTREE_PATH")"
if [ -f "$SCRIPT_DIR/erp-docker-agent-cleanup" ]; then
  bash "$SCRIPT_DIR/erp-docker-agent-cleanup" --apply --no-logs --project-name "$WORKTREE_COMPOSE_PROJECT" || {
    echo "WARN: Docker cleanup returned non-zero; continuing with worktree removal."
  }
else
  echo "WARN: erp-docker-agent-cleanup not found; skipping Docker cleanup."
fi

# ----- Remove worktree -----
echo "INFO: Removing worktree: $WORKTREE_PATH"
if ! git worktree remove "$WORKTREE_PATH"; then
  echo "ERROR: Failed to remove worktree: $WORKTREE_PATH"
  echo "Recovery: ensure no shell or process still holds the directory."
  exit 1
fi
echo "OK: Worktree removed."

# After worktree removal, the current directory is orphaned. Switch to main repo root.
cd "$MAIN_PATH"

# ----- Delete local branch -----
echo "INFO: Deleting local branch: $BRANCH"
LATEST_PR_STATE="$(gh_retry gh pr view "$PR_NUMBER" --json state --jq '.state')"
if [ "$LATEST_PR_STATE" != "MERGED" ]; then
  echo "ERROR: refusing forced branch deletion because PR #$PR_NUMBER is not MERGED: $LATEST_PR_STATE"
  exit 1
fi

if git rev-parse --verify "refs/heads/$BRANCH" >/dev/null 2>&1; then
  git branch -D "$BRANCH"
  echo "OK: Local branch deleted: $BRANCH"
else
  echo "INFO: Local branch already absent: $BRANCH"
fi

# ----- Delete remote branch and prune -----
if git ls-remote --exit-code --heads origin "$BRANCH" >/dev/null 2>&1; then
  echo "INFO: Deleting remote branch: $BRANCH"
  git push origin --delete "$BRANCH" || true
fi

git remote prune origin

# ----- Print final state -----
echo "FINALIZED_PR: #$PR_NUMBER"
echo "PR_TITLE: $PR_TITLE"
echo "MAIN_CI_RUN_ID: $MAIN_CI_RUN_ID"

echo
echo "==== FINAL GIT STATUS ===="
git status --short

echo
echo "==== FINAL WORKTREE LIST ===="
git worktree list
