#!/usr/bin/env bash
set -u
set -o pipefail

TASK_NAME="${1:-terminal-run}"

if GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  cd "$GIT_ROOT" || exit 1
fi

mkdir -p logs/terminal

SAFE_TASK_NAME="$(printf '%s' "$TASK_NAME" | tr -c 'A-Za-z0-9._-' '-')"
LOG_FILE="logs/terminal/${SAFE_TASK_NAME}-$(date +%Y%m%d-%H%M%S).log"
TMP_SCRIPT="$(mktemp)"

cleanup() {
  rm -f "$TMP_SCRIPT"
}
trap cleanup EXIT

cat > "$TMP_SCRIPT"

{
  echo "============================================================"
  echo "ERP LOGGED RUN"
  echo "============================================================"
  echo "TASK: $TASK_NAME"
  echo "LOG_FILE: $LOG_FILE"
  echo "DATE: $(date)"
  echo "PWD: $(pwd)"
  echo "============================================================"
  echo

  bash "$TMP_SCRIPT"
  COMMAND_EXIT_CODE=$?

  echo
  echo "============================================================"
  echo "COMMAND EXIT CODE"
  echo "============================================================"
  echo "$COMMAND_EXIT_CODE"

  exit "$COMMAND_EXIT_CODE"
} 2>&1 | tee "$LOG_FILE"

PIPE_EXIT_CODE=${PIPESTATUS[0]}

echo
echo "============================================================"
echo "LOG SAVED"
echo "============================================================"
echo "$LOG_FILE"

echo
echo "============================================================"
echo "COPY LOG TO CLIPBOARD"
echo "============================================================"

if command -v clip.exe >/dev/null 2>&1; then
  clip.exe < "$LOG_FILE"
  echo "OK: log copied to Windows clipboard. Paste it into ChatGPT with Ctrl+V."
else
  echo "clip.exe not found. Open the log manually:"
  echo "$LOG_FILE"
fi

exit "$PIPE_EXIT_CODE"
