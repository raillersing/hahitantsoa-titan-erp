#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd)"
COMPOSE_FILE="$REPO_ROOT/compose.agent-ci.yaml"

cd "$REPO_ROOT"

DRY_RUN=1
ALLOW_VOLUMES=0
SHOW_LOGS=1
COMPOSE_PROJECT_OVERRIDE=""

print_usage() {
  cat <<"USAGE"
Usage:
  scripts/dev/erp-docker-agent-cleanup [options]

Options:
  --apply               Perform changes (default is dry-run).
  --project-name <name> Explicit Docker Compose project name to target.
  --dangerous-allow-volume-removal
                        Allow removal of ERP agent CI volumes.
  --no-logs             Suppress docker ps/system df logging.
  --help                Show this help.

Purpose:
  Safely stop and remove ERP agent CI Docker containers, networks, and
  optionally volumes created by compose.agent-ci.yaml.

  Uses docker compose down --remove-orphans as the primary cleanup
  mechanism, scoped to the ERP project.

Project targeting:
  By default this targets the active worktree basename, which matches Docker
  Compose's default project naming when scripts/dev/erp-backend-compose-ci ran
  from that worktree.

  If the task worktree was already removed, pass the former worktree basename
  through --project-name to clean only that project's ERP resources from a safe
  remaining ERP worktree.

Guarantees:
  - Never removes volumes unless --dangerous-allow-volume-removal is set.
  - Never touches n8n or non-ERP containers.
  - Dry-run by default; use --apply to perform changes.
  - Logs docker ps and docker system df before and after cleanup.
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --apply)
      DRY_RUN=0
      ;;
    --project-name)
      shift
      COMPOSE_PROJECT_OVERRIDE="${1:-}"
      ;;
    --dangerous-allow-volume-removal)
      ALLOW_VOLUMES=1
      ;;
    --no-logs)
      SHOW_LOGS=0
      ;;
    help|--help|-h)
      print_usage
      exit 0
      ;;
    -*)
      echo "ERROR: unknown option: $1"
      print_usage
      exit 2
      ;;
    *)
      echo "ERROR: unexpected argument: $1"
      print_usage
      exit 2
      ;;
  esac
  shift
done

require_option_value() {
  local name="$1"
  local value="$2"
  if [ -z "$value" ] || [[ "$value" == --* ]]; then
    echo "ERROR: missing value for $name"
    exit 2
  fi
}

if [ -n "$COMPOSE_PROJECT_OVERRIDE" ]; then
  require_option_value "--project-name" "$COMPOSE_PROJECT_OVERRIDE"
fi

if [ ! -f "$COMPOSE_FILE" ]; then
  echo "ERROR: missing compose file: $COMPOSE_FILE"
  exit 1
fi

DEFAULT_COMPOSE_PROJECT="$(basename "$REPO_ROOT")"
COMPOSE_PROJECT="${COMPOSE_PROJECT_OVERRIDE:-$DEFAULT_COMPOSE_PROJECT}"

case "$COMPOSE_PROJECT" in
  ""|*/*|*\\*|.*)
    echo "ERROR: unsafe compose project name: $COMPOSE_PROJECT"
    exit 1
    ;;
esac

if [[ "$COMPOSE_PROJECT" != hahitantsoa-titan-erp* ]]; then
  echo "ERROR: refusing non-ERP compose project target: $COMPOSE_PROJECT"
  echo "Use an ERP worktree basename such as hahitantsoa-titan-erp-<task>."
  exit 1
fi

COMPOSE_LABEL="com.docker.compose.project=${COMPOSE_PROJECT}"

echo "============================================================"
echo "ERP Agent CI Docker Cleanup"
echo "============================================================"
echo "COMPOSE_FILE: $COMPOSE_FILE"
echo "COMPOSE_PROJECT: $COMPOSE_PROJECT"
echo "TIMESTAMP: $(date -u +%Y-%m-%dT%H:%M:%SZ)"

if [ "$DRY_RUN" -eq 1 ]; then
  echo "MODE: dry-run (use --apply to perform changes)"
else
  echo "MODE: apply"
fi

if [ "$ALLOW_VOLUMES" -eq 1 ]; then
  echo "VOLUMES: removal allowed"
else
  echo "VOLUMES: preserved"
fi

echo ""

# Pre-cleanup logging
if [ "$SHOW_LOGS" -eq 1 ]; then
  echo "--- Pre-cleanup state ---"
  echo "Running containers:"
  docker ps --format "table {{.Names}}	{{.Image}}	{{.Status}}" 2>/dev/null || echo "(unable to list)"
  echo ""
  echo "Disk usage:"
  docker system df 2>/dev/null || echo "(unable to show)"
  echo ""
fi

# Primary cleanup: docker compose down (project-scoped)
echo "--- Primary cleanup: docker compose down --remove-orphans ---"

DOWN_FLAGS=("--remove-orphans")
if [ "$ALLOW_VOLUMES" -eq 1 ]; then
  DOWN_FLAGS+=("-v")
fi

if [ "$DRY_RUN" -eq 0 ]; then
  echo "Executing: docker compose -p $COMPOSE_PROJECT -f $COMPOSE_FILE down ${DOWN_FLAGS[*]}"
  docker compose -p "$COMPOSE_PROJECT" -f "$COMPOSE_FILE" down "${DOWN_FLAGS[@]}" || {
    echo "WARN: docker compose down exited non-zero; proceeding to fallback."
  }
else
  echo "WOULD execute: docker compose -p $COMPOSE_PROJECT -f $COMPOSE_FILE down ${DOWN_FLAGS[*]}"
fi

echo ""

# Fallback cleanup: label-based removal
echo "--- Fallback cleanup: label-based removal ---"

ERP_CONTAINERS="$(
  docker ps -a --filter "label=${COMPOSE_LABEL}" \
    --format "{{.Names}}" 2>/dev/null || true
)"

if [ -z "$ERP_CONTAINERS" ]; then
  echo "No leftover ERP containers found."
else
  echo "$ERP_CONTAINERS" | while IFS= read -r container; do
    echo "Container: $container"
    if [ "$DRY_RUN" -eq 0 ]; then
      echo "  -> Stopping..."
      docker stop "$container" 2>/dev/null || true
      echo "  -> Removing..."
      docker rm "$container" 2>/dev/null || true
    else
      echo "  -> WOULD stop and remove"
    fi
  done
fi

echo ""

ERP_NETWORKS="$(
  docker network ls --filter "label=${COMPOSE_LABEL}" \
    --format "{{.Name}}" 2>/dev/null || true
)"

if [ -z "$ERP_NETWORKS" ]; then
  echo "No leftover ERP networks found."
else
  echo "$ERP_NETWORKS" | while IFS= read -r network; do
    case "$network" in
      bridge|host|none)
        echo "Skipping default network: $network"
        continue
        ;;
    esac
    echo "Network: $network"
    if [ "$DRY_RUN" -eq 0 ]; then
      echo "  -> Removing..."
      docker network rm "$network" 2>/dev/null || true
    else
      echo "  -> WOULD remove"
    fi
  done
fi

echo ""

if [ "$ALLOW_VOLUMES" -eq 1 ]; then
  echo "--- Volume removal ---"
  ERP_VOLUMES="$(
    docker volume ls --filter "label=${COMPOSE_LABEL}" \
      --format "{{.Name}}" 2>/dev/null || true
  )"

  if [ -z "$ERP_VOLUMES" ]; then
    echo "No ERP volumes found."
  else
    echo "$ERP_VOLUMES" | while IFS= read -r volume; do
      echo "Volume: $volume"
      if [ "$DRY_RUN" -eq 0 ]; then
        echo "  -> Removing..."
        docker volume rm "$volume" 2>/dev/null || true
      else
        echo "  -> WOULD remove"
      fi
    done
  fi
else
  echo "--- Volumes preserved ---"
  echo "Volumes are intentionally kept to preserve test data."
  echo "  - postgres_agent_ci_data"
  echo "  - redis_agent_ci_data"
fi

echo ""

# Post-cleanup logging
if [ "$SHOW_LOGS" -eq 1 ]; then
  echo "--- Post-cleanup state ---"
  echo "Running containers:"
  docker ps --format "table {{.Names}}	{{.Image}}	{{.Status}}" 2>/dev/null || echo "(unable to list)"
  echo ""
  echo "Disk usage:"
  docker system df 2>/dev/null || echo "(unable to show)"
  echo ""
fi

echo "--- Non-ERP resources (untouched) ---"
echo "Resources NOT modified:"
echo "  - n8n container"
echo "  - Docker volumes (unless dangerous-allow set)"
echo "  - Backend/frontend dependency caches"
echo "  - Any non-ERP containers or networks"
echo ""

echo "============================================================"
if [ "$DRY_RUN" -eq 1 ]; then
  echo "Dry-run complete. Run with --apply to perform cleanup."
else
  echo "Cleanup complete."
fi
echo "============================================================"
