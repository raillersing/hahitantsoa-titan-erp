#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd)"

cd "$REPO_ROOT"

print_usage() {
  cat <<'USAGE'
Usage:
  scripts/dev/erp-secret-scan-local [--all] [--paths-only]

Purpose:
  Non-destructively scan candidate changes for secret-like patterns without
  printing full values. Use --all for a repository-wide audit.

Behavior:
  - scans branch, staged, unstaged, and untracked candidate files by default
  - scans all eligible repository files only with --all
  - never reads .env or .env.* files
  - never follows symbolic links while reading content
  - never prints full matched secret values
  - reports file, line, pattern label, and a redacted snippet only

Examples:
  scripts/dev/erp-secret-scan-local --help
  scripts/dev/erp-secret-scan-local
  scripts/dev/erp-secret-scan-local --paths-only
  scripts/dev/erp-secret-scan-local --all
USAGE
}

PATHS_ONLY=0
SCAN_ALL=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --all)
      SCAN_ALL=1
      ;;
    --paths-only)
      PATHS_ONLY=1
      ;;
    help|--help|-h)
      print_usage
      exit 0
      ;;
    *)
      echo "ERROR: unknown argument '$1'"
      print_usage
      exit 2
      ;;
  esac
  shift
done

python3 - "$REPO_ROOT" "$PATHS_ONLY" "$SCAN_ALL" <<'PY'
from __future__ import annotations

import os
import re
import subprocess
import sys
from pathlib import Path

repo_root = Path(sys.argv[1])
paths_only = sys.argv[2] == "1"
scan_all = sys.argv[3] == "1"

exclude_dirs = {
    ".git",
    "node_modules",
    ".venv",
    "dist",
    "build",
    "__pycache__",
}

exclude_names = {
    ".env",
}

exclude_suffixes = (
    ".env.example",
    ".pem",
    ".key",
    ".p12",
    ".pfx",
    ".crt",
    ".cer",
    ".der",
    ".kdbx",
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".pdf",
    ".zip",
)

patterns: list[tuple[str, re.Pattern[str]]] = [
    ("github_token", re.compile(r"\bgh[pousr]_[A-Za-z0-9]{20,}\b")),
    ("openai_key", re.compile(r"\bsk-[A-Za-z0-9]{20,}\b")),
    ("aws_access_key", re.compile(r"\bAKIA[0-9A-Z]{16}\b")),
    ("private_key_header", re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----")),
    ("generic_secret_assignment", re.compile(r"(?i)\b(secret|token|password|api[_-]?key)\b\s*[:=]\s*['\"]?([A-Za-z0-9_\-+/=]{8,})")),
    ("authorization_bearer", re.compile(r"(?i)\bauthorization\b.{0,20}\bbearer\s+[A-Za-z0-9._\-+/=]{8,}")),
    ("cookie_assignment", re.compile(r"(?i)\b(set-cookie|cookie)\b.{0,20}[=:]\s*[^;\s]{8,}")),
]

def is_excluded(path: Path) -> bool:
    parts = set(path.parts)
    if parts & exclude_dirs:
        return True
    if any(part == ".env" or part.startswith(".env.") for part in path.parts):
        return True
    name = path.name
    if name in exclude_names or name.startswith(".env."):
        return True
    return any(name.endswith(suffix) for suffix in exclude_suffixes)

def git_bytes(root: Path, *args: str) -> bytes:
    proc = subprocess.run(
        ["git", *args],
        cwd=root,
        check=False,
        capture_output=True,
    )
    if proc.returncode != 0:
        print("ERROR: a secret-scan Git command failed", file=sys.stderr)
        raise SystemExit(2)
    return proc.stdout

def git_paths(root: Path, *args: str) -> list[str]:
    output = git_bytes(root, *args)
    return [os.fsdecode(value) for value in output.split(b"\0") if value]

def git_ref_exists(root: Path, ref: str) -> bool:
    return subprocess.run(
        ["git", "rev-parse", "--verify", ref],
        cwd=root,
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    ).returncode == 0

def read_working_content(path: Path, rel: Path) -> bytes:
    try:
        if path.is_symlink():
            return os.fsencode(os.readlink(path))
        return path.read_bytes()
    except OSError:
        print(f"ERROR: candidate file is unreadable: {redact_line(str(rel))}", file=sys.stderr)
        raise SystemExit(2)

def iter_all_contents(root: Path):
    for base, dirs, files in os.walk(root):
        dirs[:] = [d for d in dirs if d not in exclude_dirs]
        for filename in files:
            path = Path(base) / filename
            rel = path.relative_to(root)
            if is_excluded(rel):
                continue
            yield rel, read_working_content(path, rel)

def iter_candidate_contents(root: Path):
    if git_ref_exists(root, "origin/main"):
        base_ref = "origin/main"
    elif git_ref_exists(root, "main"):
        base_ref = "main"
    else:
        print("ERROR: candidate scan requires origin/main or main", file=sys.stderr)
        raise SystemExit(2)

    branch_paths = git_paths(
        root,
        "diff",
        "--name-only",
        "-z",
        "--diff-filter=ACMR",
        f"{base_ref}...HEAD",
    )
    staged_paths = git_paths(
        root, "diff", "--cached", "--name-only", "-z", "--diff-filter=ACMR"
    )
    working_paths = set(
        git_paths(root, "diff", "--name-only", "-z", "--diff-filter=ACMR")
    )
    working_paths.update(
        git_paths(root, "ls-files", "--others", "--exclude-standard", "-z")
    )

    for rel_value in sorted(set(branch_paths)):
        rel = Path(rel_value)
        if not is_excluded(rel):
            yield rel, git_bytes(root, "show", f"HEAD:{rel_value}")

    for rel_value in sorted(set(staged_paths)):
        rel = Path(rel_value)
        if not is_excluded(rel):
            yield rel, git_bytes(root, "show", f":{rel_value}")

    for rel_value in sorted(working_paths):
        rel = Path(rel_value)
        path = root / rel
        if path.is_file() and not is_excluded(rel):
            yield rel, read_working_content(path, rel)

def redact_line(line: str) -> str:
    def repl(match: re.Match[str]) -> str:
        text = match.group(0)
        if "=" in text:
            left, _, _ = text.partition("=")
            return f"{left}=<redacted>"
        if ":" in text:
            left, _, _ = text.partition(":")
            return f"{left}:<redacted>"
        if "bearer" in text.lower():
            prefix = text[: text.lower().find("bearer") + len("bearer")]
            return f"{prefix} <redacted>"
        return "<redacted>"

    redacted = line.rstrip("\n")
    for _, pattern in patterns:
        redacted = pattern.sub(repl, redacted)
    return redacted[:200]

def is_known_non_secret_context(
    path: Path, line: str, label: str, match: re.Match[str]
) -> bool:
    synthetic_test_passwords = {
        "LocalDetailSmokePassword123",
        "LocalPassword123",
        "password",
        "OldPassword123",
        "test-pass",
        "test-password",
        "LocalSmokePassword123",
    }
    if label == "generic_secret_assignment" and match.group(2) == "redacted":
        value_start, value_end = match.span(2)
        exact_placeholder = (
            line[value_start - 1 : value_start] == "<"
            and line[value_end : value_end + 1] == ">"
        )
        if exact_placeholder:
            return True

    if (
        label == "generic_secret_assignment"
        and match.group(1).lower() == "password"
        and match.group(2) in synthetic_test_passwords
    ):
        return True

    if label == "cookie_assignment":
        if match.group(0).endswith("<redacted>"):
            return True
        dependency_name = "tough" + "-cookie"
        dependency = re.search(
            rf'"(?:node_modules/)?{re.escape(dependency_name)}"\s*:'
            r'\s*"\^[0-9]+\.[0-9]+\.[0-9]+"',
            line,
        )
        return (
            dependency is not None
            and dependency.start() <= match.start()
            and match.start() < dependency.end()
        )

    return False

results: list[str] = []
paths_seen: set[str] = set()

contents_to_scan = (
    iter_all_contents(repo_root) if scan_all else iter_candidate_contents(repo_root)
)

for rel_path, content in contents_to_scan:
    if b"\x00" in content[:2048]:
        continue
    text = content.decode("utf-8", errors="replace")
    for lineno, line in enumerate(text.splitlines(), start=1):
        for label, pattern in patterns:
            actionable_match = any(
                not is_known_non_secret_context(rel_path, line, label, match)
                for match in pattern.finditer(line)
            )
            if actionable_match:
                rel_str = redact_line(str(rel_path))
                if paths_only:
                    if rel_str not in paths_seen:
                        results.append(rel_str)
                        paths_seen.add(rel_str)
                else:
                    results.append(f"{rel_str}:{lineno}: {label}: {redact_line(line)}")
                break

secret_path_pattern = re.compile(
    r"(^|/)\.env($|[./])|\.pem$|\.key$|id_rsa|id_ed25519"
)
for raw_entry in git_bytes(repo_root, "status", "--porcelain=v1", "-z").split(b"\0"):
    if not raw_entry:
        continue
    entry = os.fsdecode(raw_entry)
    path_value = entry[3:] if len(entry) >= 3 and entry[2] == " " else entry
    if secret_path_pattern.search(path_value):
        safe_path = redact_line(path_value)
        result = safe_path if paths_only else f"git-status: path-stop: {safe_path}"
        results.append(result)

if results:
    print("Potential secret or log-hygiene issues detected:")
    for row in sorted(dict.fromkeys(results)):
        print(row)
    sys.exit(1)

mode = "full repository" if scan_all else "candidate changes"
print(f"No secret-like findings detected in {mode} by local redacted scan.")
PY
