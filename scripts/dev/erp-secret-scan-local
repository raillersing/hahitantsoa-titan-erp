#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd)"

cd "$REPO_ROOT"

print_usage() {
  cat <<'USAGE'
Usage:
  scripts/dev/erp-secret-scan-local [--paths-only]

Purpose:
  Non-destructively scan repository files and logged terminal output for
  secret-like patterns without printing full values.

Behavior:
  - never reads .env or .env.* files
  - never prints full matched secret values
  - reports file, line, pattern label, and a redacted snippet only

Examples:
  scripts/dev/erp-secret-scan-local --help
  scripts/dev/erp-secret-scan-local
  scripts/dev/erp-secret-scan-local --paths-only
USAGE
}

PATHS_ONLY=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --paths-only)
      PATHS_ONLY=1
      ;;
    help|--help|-h)
      print_usage
      exit 0
      ;;
    *)
      echo "ERROR: unknown argument '$1'"
      print_usage
      exit 2
      ;;
  esac
  shift
done

python3 - "$REPO_ROOT" "$PATHS_ONLY" <<'PY'
from __future__ import annotations

import os
import re
import subprocess
import sys
from pathlib import Path

repo_root = Path(sys.argv[1])
paths_only = sys.argv[2] == "1"

exclude_dirs = {
    ".git",
    "node_modules",
    ".venv",
    "dist",
    "build",
    "__pycache__",
}

exclude_names = {
    ".env",
}

exclude_suffixes = (
    ".env.example",
    ".pem",
    ".key",
    ".p12",
    ".pfx",
    ".crt",
    ".cer",
    ".der",
    ".kdbx",
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".pdf",
    ".zip",
)

patterns: list[tuple[str, re.Pattern[str]]] = [
    ("github_token", re.compile(r"\bgh[pousr]_[A-Za-z0-9]{20,}\b")),
    ("openai_key", re.compile(r"\bsk-[A-Za-z0-9]{20,}\b")),
    ("aws_access_key", re.compile(r"\bAKIA[0-9A-Z]{16}\b")),
    ("private_key_header", re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----")),
    ("generic_secret_assignment", re.compile(r"(?i)\b(secret|token|password|api[_-]?key)\b\s*[:=]\s*['\"]?([A-Za-z0-9_\-+/=]{8,})")),
    ("authorization_bearer", re.compile(r"(?i)\bauthorization\b.{0,20}\bbearer\s+[A-Za-z0-9._\-+/=]{8,}")),
    ("cookie_assignment", re.compile(r"(?i)\b(set-cookie|cookie)\b.{0,20}[=:]\s*[^;\s]{8,}")),
]

def is_excluded(path: Path) -> bool:
    parts = set(path.parts)
    if parts & exclude_dirs:
        return True
    name = path.name
    if name in exclude_names or name.startswith(".env."):
        return True
    return any(name.endswith(suffix) for suffix in exclude_suffixes)

def iter_candidate_files(root: Path):
    for base, dirs, files in os.walk(root):
        dirs[:] = [d for d in dirs if d not in exclude_dirs]
        for filename in files:
            path = Path(base) / filename
            rel = path.relative_to(root)
            if is_excluded(rel):
                continue
            yield path, rel

def is_binary(path: Path) -> bool:
    try:
        with path.open("rb") as fh:
            chunk = fh.read(2048)
        return b"\x00" in chunk
    except OSError:
        return True

def redact_line(line: str, pattern: re.Pattern[str]) -> str:
    def repl(match: re.Match[str]) -> str:
        text = match.group(0)
        if "=" in text:
            left, _, _ = text.partition("=")
            return f"{left}=<redacted>"
        if ":" in text:
            left, _, _ = text.partition(":")
            return f"{left}:<redacted>"
        if "bearer" in text.lower():
            prefix = text[: text.lower().find("bearer") + len("bearer")]
            return f"{prefix} <redacted>"
        return "<redacted>"

    redacted = pattern.sub(repl, line.rstrip("\n"))
    return redacted[:200]

results: list[str] = []
paths_seen: set[str] = set()

for abs_path, rel_path in iter_candidate_files(repo_root):
    if is_binary(abs_path):
        continue
    try:
        with abs_path.open("r", encoding="utf-8", errors="replace") as fh:
            for lineno, line in enumerate(fh, start=1):
                for label, pattern in patterns:
                    if pattern.search(line):
                        rel_str = str(rel_path)
                        if paths_only:
                            if rel_str not in paths_seen:
                                results.append(rel_str)
                                paths_seen.add(rel_str)
                        else:
                            results.append(f"{rel_str}:{lineno}: {label}: {redact_line(line, pattern)}")
                        break
    except OSError:
        continue

if not paths_only:
    try:
        proc = subprocess.run(
            ["git", "status", "--short"],
            cwd=repo_root,
            check=False,
            capture_output=True,
            text=True,
        )
        for line in proc.stdout.splitlines():
            if re.search(r"(^| )\.env|\.env\.|\.env$|\.pem$|\.key$|id_rsa|id_ed25519", line):
                results.append(f"git-status: path-stop: {line.strip()}")
    except OSError:
        pass

if results:
    print("Potential secret or log-hygiene issues detected:")
    for row in sorted(dict.fromkeys(results)):
        print(row)
    sys.exit(1)

print("No secret-like findings detected by local redacted scan.")
PY
