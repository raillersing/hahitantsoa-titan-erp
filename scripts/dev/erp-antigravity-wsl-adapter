#!/usr/bin/env bash
# erp-antigravity-wsl-adapter
# Bash entrypoint for the Antigravity Windows-to-WSL adapter wrapper.

set -Eeuo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd)"
cd "$REPO_ROOT"

if [ "$PWD" != "$REPO_ROOT" ]; then
  echo "ERROR: adapter must execute in repository root: $REPO_ROOT"
  exit 1
fi

MODE="${1:-}"
if [ -z "$MODE" ]; then
  echo "ERROR: missing Mode parameter."
  exit 2
fi

shift

case "$MODE" in
  task-start)
    if [ "$#" -ne 0 ]; then
      echo "ERROR: task-start mode accepts no extra parameters."
      exit 2
    fi
    echo "INFO: Running task-start sequence via erp-logged-run..."
    scripts/dev/erp-logged-run task-start <<'EOF'
set -euo pipefail
bash scripts/dev/erp-agent-task-start
bash scripts/dev/erp-agent-profile-validate
bash scripts/dev/erp-orchestrator-state-check
bash scripts/dev/erp-task-queue-validate
EOF
    ;;

  finalize-pr)
    PR_NUMBER="${1:-}"
    if [ -z "$PR_NUMBER" ]; then
      echo "ERROR: missing PR number for finalize-pr mode."
      exit 2
    fi
    shift

    TASK_BRANCH="${1:-}"
    if [ -z "$TASK_BRANCH" ]; then
      echo "ERROR: missing TaskBranch for finalize-pr mode."
      exit 2
    fi
    shift

    TASK_WORKTREE=""
    declare -a ALLOW_PATHS=()

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --task-worktree)
          shift
          TASK_WORKTREE="${1:-}"
          ;;
        --allow)
          shift
          ALLOW_PATHS+=("${1:-}")
          ;;
        *)
          echo "ERROR: unknown finalize-pr argument: $1"
          exit 2
          ;;
      esac
      shift
    done

    if [ "${#ALLOW_PATHS[@]}" -eq 0 ]; then
      echo "ERROR: at least one Allow path is required."
      exit 2
    fi

    # Build the finalization command arguments
    declare -a FINALIZER_ARGS=("$PR_NUMBER" --task-branch "$TASK_BRANCH")
    if [ -n "$TASK_WORKTREE" ]; then
      FINALIZER_ARGS+=(--task-worktree "$TASK_WORKTREE")
    fi
    for path in "${ALLOW_PATHS[@]}"; do
      FINALIZER_ARGS+=(--allow "$path")
    done

    FINALIZER_CMD="bash scripts/dev/erp-pr-finalize-from-root"
    for arg in "${FINALIZER_ARGS[@]}"; do
      FINALIZER_CMD+=" $(printf '%q' "$arg")"
    done

    echo "INFO: Running PR finalization via erp-logged-run..."
    scripts/dev/erp-logged-run task-pr-finalize-adapter <<EOF
set -euo pipefail
$FINALIZER_CMD
EOF
    ;;

  repo-status)
    if [ "$#" -ne 0 ]; then
      echo "ERROR: repo-status mode accepts no extra parameters."
      exit 2
    fi
    echo "INFO: Running repo-status check via erp-logged-run..."
    scripts/dev/erp-logged-run repo-status <<'EOF'
set -euo pipefail
echo "==== CURRENT BRANCH ===="
git branch --show-current
echo "==== GIT STATUS ===="
git status --short
echo "==== RECENT COMMITS ===="
git log --oneline -5
echo "==== GIT WORKTREE LIST ===="
git worktree list
echo "==== OPEN PR LIST ===="
gh pr list
echo "==== F140D STATUS ===="
if git status --short | grep -F "docs/audits/F140D_OPENCODE_WSL_NATIVE_EVALUATION.md" >/dev/null; then
  echo "F140D status: untracked/modified"
else
  echo "F140D status: tracked/clean"
fi
EOF
    ;;

  pr-checks)
    PR_NUMBER="${1:-}"
    if [ -z "$PR_NUMBER" ]; then
      echo "ERROR: missing PR number for pr-checks mode."
      exit 2
    fi
    echo "INFO: Running pr-checks check via erp-logged-run..."
    scripts/dev/erp-logged-run pr-checks-"$PR_NUMBER" <<EOF
set -euo pipefail
echo "==== PR METADATA ===="
echo "PR Number: \$(gh pr view "$PR_NUMBER" --json number --jq '.number')"
echo "Title: \$(gh pr view "$PR_NUMBER" --json title --jq '.title')"
echo "State: \$(gh pr view "$PR_NUMBER" --json state --jq '.state')"
echo "Base: \$(gh pr view "$PR_NUMBER" --json baseRefName --jq '.baseRefName')"
echo "Head: \$(gh pr view "$PR_NUMBER" --json headRefName --jq '.headRefName')"
echo "Mergeable: \$(gh pr view "$PR_NUMBER" --json mergeable --jq '.mergeable')"

echo "==== CI CHECKS ===="
BE_STATUS=\$(gh pr view "$PR_NUMBER" --json statusCheckRollup --jq '.statusCheckRollup[] | select((.name // .context) == "Backend quality") | .conclusion' 2>/dev/null || echo "")
FE_STATUS=\$(gh pr view "$PR_NUMBER" --json statusCheckRollup --jq '.statusCheckRollup[] | select((.name // .context) == "Frontend quality") | .conclusion' 2>/dev/null || echo "")

echo "Backend quality: \$BE_STATUS"
echo "Frontend quality: \$FE_STATUS"

if [ "\$BE_STATUS" = "SUCCESS" ] && [ "\$FE_STATUS" = "SUCCESS" ]; then
  echo "Classification: PASS"
elif [ "\$BE_STATUS" = "FAILURE" ] || [ "\$FE_STATUS" = "FAILURE" ]; then
  echo "Classification: FAIL"
else
  echo "Classification: PENDING"
fi
EOF
    ;;

  pr-create)
    PR_HEAD="${1:-}"
    PR_BASE="${2:-}"
    PR_TITLE="${3:-}"
    PR_BODY="${4:-}"

    if [ -z "$PR_HEAD" ]; then
      echo "ERROR: missing PrHead."
      exit 2
    fi
    if [ "$PR_HEAD" = "main" ] || [ "$PR_HEAD" = "master" ]; then
      echo "ERROR: PrHead cannot be main or master."
      exit 2
    fi
    if [ "$PR_BASE" != "main" ]; then
      echo "ERROR: PrBase must be main."
      exit 2
    fi
    if [ -z "$PR_TITLE" ]; then
      echo "ERROR: missing PrTitle."
      exit 2
    fi
    if [ -z "$PR_BODY" ]; then
      echo "ERROR: missing PrBody."
      exit 2
    fi

    # Pre-escape strings for heredoc safety
    H_HEAD=$(printf '%q' "$PR_HEAD")
    H_BASE=$(printf '%q' "$PR_BASE")
    H_TITLE=$(printf '%q' "$PR_TITLE")
    H_BODY=$(printf '%q' "$PR_BODY")

    echo "INFO: Running PR creation via erp-logged-run..."
    scripts/dev/erp-logged-run task-pr-create-adapter <<EOF
set -euo pipefail
PR_HEAD=$H_HEAD
PR_BASE=$H_BASE
PR_TITLE=$H_TITLE
PR_BODY=$H_BODY

echo "INFO: Confirming branch exists on origin..."
if [ -z "\$(git ls-remote --heads origin "\$PR_HEAD")" ]; then
  echo "ERROR: branch \$PR_HEAD does not exist on origin."
  exit 1
fi

echo "INFO: Checking for existing open PR..."
PR_EXISTING=\$(gh pr list --head "\$PR_HEAD" --base "\$PR_BASE" --state open --json number --jq '.[0].number' 2>/dev/null || echo "")

if [ -n "\$PR_EXISTING" ]; then
  echo "INFO: Reusing existing open PR #\$PR_EXISTING"
else
  echo "INFO: Creating new PR..."
  gh pr create --head "\$PR_HEAD" --base "\$PR_BASE" --title "\$PR_TITLE" --body "\$PR_BODY"
fi

echo "==== PR DETAILS ===="
gh pr view "\$PR_HEAD" --json number,title,baseRefName,headRefName,state,mergeable,url --jq '"PR Number: \(.number)\nTitle: \(.title)\nBase: \(.baseRefName)\nHead: \(.headRefName)\nState: \(.state)\nMergeable: \(.mergeable)\nURL: \(.url)"'
EOF
    ;;

  task-branch-start)
    TASK_BRANCH="${1:-}"
    if [ -z "$TASK_BRANCH" ]; then
      echo "ERROR: missing TaskBranch."
      exit 2
    fi
    if [ "$TASK_BRANCH" = "main" ] || [ "$TASK_BRANCH" = "master" ]; then
      echo "ERROR: TaskBranch cannot be main or master."
      exit 2
    fi
    if [[ ! "$TASK_BRANCH" =~ ^(docs/|feat/|fix/|chore/) ]]; then
      echo "ERROR: TaskBranch must start with docs/, feat/, fix/, or chore/."
      exit 2
    fi
    shift

    TASK_WORKTREE=""
    TASK_BASE="main"

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --task-worktree)
          shift
          TASK_WORKTREE="${1:-}"
          ;;
        --task-base)
          shift
          TASK_BASE="${1:-}"
          ;;
        *)
          echo "ERROR: unknown task-branch-start option: $1"
          exit 2
          ;;
      esac
      shift
    done

    if [ "$TASK_BASE" != "main" ]; then
      echo "ERROR: TaskBase must be main."
      exit 2
    fi

    # Pre-escape strings for heredoc safety
    H_BRANCH=$(printf '%q' "$TASK_BRANCH")
    H_WORKTREE=$(printf '%q' "$TASK_WORKTREE")
    H_BASE=$(printf '%q' "$TASK_BASE")

    echo "INFO: Running task-branch-start via erp-logged-run..."
    scripts/dev/erp-logged-run task-branch-start <<EOF
set -euo pipefail
TASK_BRANCH=$H_BRANCH
TASK_WORKTREE=$H_WORKTREE
TASK_BASE=$H_BASE

echo "INFO: Confirming repository root branch is main..."
CURRENT_ROOT_BRANCH=\$(git branch --show-current)
if [ "\$CURRENT_ROOT_BRANCH" != "main" ]; then
  echo "ERROR: current root branch is \$CURRENT_ROOT_BRANCH, expected main."
  exit 1
fi

echo "INFO: Confirming no tracked changes exist in root..."
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "ERROR: root worktree has dirty tracked files."
  exit 1
fi

echo "INFO: Fetching and fast-forwarding main..."
git fetch origin main
git merge --ff-only FETCH_HEAD

BASE_SHA=\$(git rev-parse HEAD)

if [ -n "\$TASK_WORKTREE" ]; then
  echo "INFO: Checking if worktree path exists..."
  if [ -d "\$TASK_WORKTREE" ]; then
    echo "ERROR: worktree path \$TASK_WORKTREE already exists."
    exit 1
  fi

  echo "INFO: Checking if branch already exists locally..."
  if git show-ref --verify --quiet "refs/heads/\$TASK_BRANCH"; then
    echo "ERROR: branch \$TASK_BRANCH already exists locally."
    exit 1
  fi

  echo "INFO: Checking if branch already exists on origin..."
  if [ -n "\$(git ls-remote --heads origin \"\$TASK_BRANCH\")" ]; then
    echo "ERROR: branch \$TASK_BRANCH already exists on origin."
    exit 1
  fi

  echo "INFO: Creating linked worktree for branch \$TASK_BRANCH..."
  git worktree add -b "\$TASK_BRANCH" "\$TASK_WORKTREE" "\$TASK_BASE"
else
  echo "INFO: Creating branch \$TASK_BRANCH in root..."
  git checkout -b "\$TASK_BRANCH" "\$TASK_BASE"
fi

echo "==== BRANCH DETAILS ===="
echo "Branch: \$TASK_BRANCH"
echo "Base Branch: \$TASK_BASE"
echo "Base SHA: \$BASE_SHA"
echo "Worktree Path: \$TASK_WORKTREE"
echo "Git Status:"
git status --short
echo "Git Worktree List:"
git worktree list
echo "F140D Status:"
if git status --short | grep -F "docs/audits/F140D_OPENCODE_WSL_NATIVE_EVALUATION.md" >/dev/null; then
  echo "F140D status: untracked/modified"
else
  echo "F140D status: tracked/clean"
fi
EOF
    ;;

  frontend-quality)
    if [ "$#" -ne 0 ]; then
      echo "ERROR: frontend-quality mode accepts no extra parameters."
      exit 2
    fi
    echo "INFO: Running frontend-quality check via erp-logged-run..."
    scripts/dev/erp-logged-run frontend-quality <<'EOF'
set -euo pipefail
bash scripts/dev/erp-frontend-quality
EOF
    ;;

  *)
    echo "ERROR: unsupported adapter mode: $MODE"
    exit 2
    ;;
esac

echo "ADAPTER_MODE: $MODE"
echo "ADAPTER_STATUS: SUCCESS"
