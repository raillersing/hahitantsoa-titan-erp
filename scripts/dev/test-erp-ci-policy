#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
classifier="$SCRIPT_DIR/erp-ci-change-policy"
gate="$SCRIPT_DIR/erp-ci-policy-gate"
repo_root="$(CDPATH= cd -- "$SCRIPT_DIR/../.." && pwd)"
workflow="$repo_root/.github/workflows/ci.yml"
tmp_root="$(mktemp -d)"
trap 'rm -rf "$tmp_root"' EXIT

assert_output() {
  local files="$1" expected="$2" actual
  actual="$(printf '%s\n' "$files" | "$classifier" --files-from -)"
  printf '%s\n' "$actual" | grep -Fqx "$expected" || {
    echo "FAIL: expected '$expected' for: $files"
    printf '%s\n' "$actual"
    exit 1
  }
}

assert_output 'docs/ai-agents/README.md' 'backend=false'
assert_output 'docs/ai-agents/README.md' 'frontend=false'
assert_output 'backend/customers/models.py' 'backend=true'
assert_output 'backend/customers/models.py' 'frontend=false'
assert_output 'frontend/src/App.tsx' 'backend=false'
assert_output 'frontend/src/App.tsx' 'frontend=true'
assert_output 'backend/identity/api.py' 'frontend=true'
assert_output '.github/workflows/ci.yml' 'level=L4'
assert_output 'unexpected-root-config.toml' 'level=L4'
assert_output '__CI_INVALID_RANGE__' 'reason=invalid-range-fail-closed'
assert_output $'docs/README.md\nbackend/customers/models.py\nfrontend/src/App.tsx' 'level=L4'

"$gate" success false skipped false skipped
"$gate" success true success false skipped
expect_gate_failure() {
  if "$gate" "$@" >/dev/null 2>&1; then
    echo "FAIL: gate accepted: $*"
    exit 1
  fi
}
expect_gate_failure success true skipped false skipped
expect_gate_failure success true failure false skipped
expect_gate_failure success false skipped true skipped
expect_gate_failure success false skipped true failure
expect_gate_failure success maybe skipped false skipped
expect_gate_failure success false cancelled false skipped
expect_gate_failure failure false skipped false skipped
expect_gate_failure success '' skipped false skipped

range_repo="$tmp_root/ranges"
git init -q -b main "$range_repo"
git -C "$range_repo" config user.email ci-policy@example.invalid
git -C "$range_repo" config user.name 'CI Policy Test'
mkdir -p "$range_repo/docs"
printf 'base\n' > "$range_repo/docs/base.md"
git -C "$range_repo" add docs/base.md
git -C "$range_repo" commit -qm base
base_sha="$(git -C "$range_repo" rev-parse HEAD)"
git -C "$range_repo" switch -qc feature
mkdir -p "$range_repo/backend/customers"
printf 'feature\n' > "$range_repo/backend/customers/models.py"
git -C "$range_repo" add backend/customers/models.py
git -C "$range_repo" commit -qm feature
feature_sha="$(git -C "$range_repo" rev-parse HEAD)"
git -C "$range_repo" switch -q main
mkdir -p "$range_repo/frontend/src"
printf 'main advance\n' > "$range_repo/frontend/src/App.tsx"
git -C "$range_repo" add frontend/src/App.tsx
git -C "$range_repo" commit -qm main-advance
main_sha="$(git -C "$range_repo" rev-parse HEAD)"

pr_result="$(cd "$range_repo" && "$classifier" --range pr "$main_sha" "$feature_sha")"
printf '%s\n' "$pr_result" | grep -Fqx 'backend=true'
printf '%s\n' "$pr_result" | grep -Fqx 'frontend=false'
push_result="$(cd "$range_repo" && "$classifier" --range push "$base_sha" "$main_sha")"
printf '%s\n' "$push_result" | grep -Fqx 'backend=false'
printf '%s\n' "$push_result" | grep -Fqx 'frontend=true'

invalid_result="$(cd "$range_repo" && "$classifier" --range push 0000000000000000000000000000000000000000 "$main_sha")"
printf '%s\n' "$invalid_result" | grep -Fqx 'reason=invalid-range-fail-closed'
empty_result="$(cd "$range_repo" && "$classifier" --range push "$main_sha" "$main_sha")"
printf '%s\n' "$empty_result" | grep -Fqx 'reason=empty-diff-fail-closed'

mkdir -p "$range_repo/backend/legacy" "$range_repo/frontend/src/legacy"
printf 'rename\n' > "$range_repo/backend/legacy/old.py"
printf 'delete\n' > "$range_repo/frontend/src/legacy/Old.tsx"
git -C "$range_repo" add backend/legacy/old.py frontend/src/legacy/Old.tsx
git -C "$range_repo" commit -qm rename-delete-base
rename_base="$(git -C "$range_repo" rev-parse HEAD)"
mkdir -p "$range_repo/backend/renamed"
git -C "$range_repo" mv backend/legacy/old.py backend/renamed/new.py
git -C "$range_repo" rm -q frontend/src/legacy/Old.tsx
git -C "$range_repo" commit -qm rename-delete
rename_head="$(git -C "$range_repo" rev-parse HEAD)"
rename_result="$(cd "$range_repo" && "$classifier" --range push "$rename_base" "$rename_head")"
printf '%s\n' "$rename_result" | grep -Fqx 'backend=true'
printf '%s\n' "$rename_result" | grep -Fqx 'frontend=true'

scope_fixture() {
  local name="$1" path="$2" expected="$3" repo
  repo="$tmp_root/scope-$name"
  git init -q -b main "$repo"
  git -C "$repo" config user.email ci-policy@example.invalid
  git -C "$repo" config user.name 'CI Policy Test'
  mkdir -p "$repo/scripts/dev"
  cp "$SCRIPT_DIR/erp-agent-scope-guard" "$repo/scripts/dev/erp-agent-scope-guard"
  git -C "$repo" add scripts/dev/erp-agent-scope-guard
  git -C "$repo" commit -qm baseline
  mkdir -p "$(dirname "$repo/$path")"
  : > "$repo/$path"
  git -C "$repo" add "$path"
  if (cd "$repo" && bash scripts/dev/erp-agent-scope-guard agent-ci >/dev/null 2>&1); then
    actual=pass
  else
    actual=fail
  fi
  [ "$actual" = "$expected" ] || { echo "FAIL: scope $path expected $expected, got $actual"; exit 1; }
}

scope_fixture workflow .github/workflows/ci.yml pass
scope_fixture other-workflow .github/workflows/release.yml fail
scope_fixture backend backend/example.py fail
scope_fixture frontend frontend/example.ts fail
scope_fixture manifest pyproject.toml fail

grep -Fq 'name: Classify changes' "$workflow"
grep -Fq 'name: CI policy gate' "$workflow"
grep -Fq 'if: always()' "$workflow"
grep -Fq 'needs.classify-changes.outputs.backend' "$workflow"
grep -Fq 'needs.classify-changes.outputs.frontend' "$workflow"

echo "ERP CI policy tests: PASS"
